        {
          "kind": "text",
          "text": "Find $\\int \\sin^2 4x \\, dx$."
        }
      ],
      "parts": null,
      "options": null,
      "answer": {
        "option_label": null,
        "summary": "$\\frac{x}{2} - \\frac{\\sin 8x}{16} + C$",
        "content": [
          {
            "kind": "text",
            "text": "Use identity $\\sin^2 A = \\frac{1 - \\cos 2A}{2}$. Thus, $\\int \\sin^2 4x \\, dx = \\int \\frac{1 - \\cos 8x}{2} \\, dx = \\frac{x}{2} - \\frac{\\sin 8x}{16} + C$."
          }
        ],
        "alternatives": null
      },
