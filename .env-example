# ─── Backend ───
SECRET_KEY=your-secret-key-here
PRODUCTION=0

# ─── Database (Supabase Postgres) ───
DB_USER=tppr_postgres
DB_PASSWORD=your-database-password
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
# Or use a full URL instead of individual vars:
# DATABASE_URL=postgresql+psycopg2://user:password@host:port/dbname?sslmode=require

SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Optional: legacy HS256 fallback (only if JWKS is unavailable)
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

BACKEND_ALLOWED_ORIGINS=http://localhost:5173

VALID_ADMIN_EMAILS=admin@example.com

# --------------- DEPLOYMENT ---------------
# GCP_PROJECT=your-project-id

# DigitalOcean App Platform
# DIGITALOCEAN_ACCESS_TOKEN=dop_v1_your-token
# DO_APP_NAME=tppr
# DO_REGION=syd
# DO_DEPLOY_MODE=image
# DO_REGISTRY_NAME=tppr
# DO_REGISTRY_REGION=syd1
# DO_REGISTRY_TIER=basic
# DO_IMAGE_REPOSITORY=tppr
# DO_APP_REPO=github-owner/repo-name # only needed when DO_DEPLOY_MODE=github
# DOCTL_VERSION=1.123.0

# DigitalOcean Functions (serverless) -- `uv run launch.py --deploy do-fns`
# DO_FN_RUNTIME=python:default            # override after `doctl serverless status --languages`
# DO_FN_SERVE_FRONTEND=0                   # 1 to bundle frontend/dist into the function