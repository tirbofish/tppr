# ─── Backend ───
SECRET_KEY=your-secret-key-here
PRODUCTION=0

# ─── Database (Supabase Postgres) ───
DB_USER=tppr_postgres
DB_PASSWORD=your-database-password
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
# Or use a full URL instead of individual vars:
# DATABASE_URL=postgresql+psycopg2://user:password@host:port/dbname?sslmode=require

SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional: legacy HS256 fallback (only if JWKS is unavailable)
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

BACKEND_ALLOWED_ORIGINS=http://localhost:5173

VALID_ADMIN_EMAILS=admin@example.com

# --------------- DEPLOYMENT ---------------
# GCP_PROJECT=your-project-id